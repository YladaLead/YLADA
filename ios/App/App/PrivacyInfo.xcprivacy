<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- YLADA app — Capacitor WKWebView wrapper loading https://www.ylada.com -->
	<!-- No cross-app tracking. Data collection happens on the web layer (ylada.com). -->

	<key>NSPrivacyTracking</key>
	<false/>

	<key>NSPrivacyTrackingDomains</key>
	<array/>

	<!-- Required Reason APIs used by Capacitor internals -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<!-- NSUserDefaults: Capacitor uses it to persist plugin config and app state -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
		<!-- File timestamps: WKWebView caching layer reads file modification times -->
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryFileTimestamp</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>C617.1</string>
			</array>
		</dict>
	</array>

	<!-- Data collected by this native app shell (not by the web layer) -->
	<!-- The web layer (ylada.com) has its own privacy policy at ylada.com/privacidade -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>

</dict>
</plist>
